{
  "name": "openloaf",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "ruler:apply": "pnpm dlx @intellectronica/ruler@latest apply --local-only",
    "dev": "node scripts/dev.mjs",
    "build": "turbo build",
    "check-types": "cross-env CI=1 turbo check-types",
    "dev:native": "node scripts/dev.mjs native",
    "dev:web": "node scripts/dev.mjs web",
    "dev:server": "node scripts/dev.mjs server",
    "kill": "node scripts/kill.mjs",
    "desktop": "node scripts/desktop.mjs",
    "test:browser": "pnpm --filter web test:browser",
    "test:browser:run": "pnpm --filter web test:browser:run",
    "test:browser:report": "pnpm --filter web test:browser:report",
    "test:browser:audit": "pnpm --filter web test:browser:audit",
    "db:push": "turbo -F @openloaf/db db:push",
    "db:studio": "turbo -F @openloaf/db db:studio",
    "db:generate": "turbo -F @openloaf/db db:generate",
    "db:migrate": "turbo -F @openloaf/db db:migrate",
    "db:seed": "turbo -F @openloaf/db db:seed",
    "analyze:hooks": "pnpm exec eslint --no-inline-config --config eslint-hooks.config.mjs apps/web/src packages/ui/src",
    "analyze:hooks:compiler": "pnpm exec eslint --no-inline-config --config eslint-hooks-compiler.config.mjs apps/web/src packages/ui/src",
    "analyze:hooks:strict": "pnpm run analyze:hooks -- --max-warnings=0",
    "analyze:hooks:runtime": "pnpm --filter web run scan",
    "analyze:duplicates": "jscpd --config .jscpd.json",
    "analyze:circular": "pnpm analyze:circular:web && pnpm analyze:circular:server && pnpm analyze:circular:desktop && pnpm analyze:circular:api && pnpm analyze:circular:ui && pnpm analyze:circular:db && pnpm analyze:circular:widget-sdk",
    "analyze:circular:web": "madge --circular --extensions ts,tsx --ts-config ./apps/web/tsconfig.json ./apps/web/src",
    "analyze:circular:server": "madge --circular --extensions ts,tsx --ts-config ./apps/server/tsconfig.json ./apps/server/src",
    "analyze:circular:desktop": "madge --circular --extensions ts,tsx --ts-config ./apps/desktop/tsconfig.json ./apps/desktop/src",
    "analyze:circular:api": "madge --circular --extensions ts,tsx --ts-config ./packages/api/tsconfig.json ./packages/api/src",
    "analyze:circular:ui": "madge --circular --extensions ts,tsx --ts-config ./packages/ui/tsconfig.json ./packages/ui/src",
    "analyze:circular:db": "madge --circular --extensions ts,tsx --ts-config ./packages/db/tsconfig.json ./packages/db/src",
    "analyze:circular:widget-sdk": "madge --circular --extensions ts,tsx --ts-config ./packages/widget-sdk/tsconfig.json ./packages/widget-sdk/src",
    "lint": "turbo lint",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --fix .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:tool-coverage": "pnpm --filter server check:tool-coverage",
    "publish:server": "pnpm --filter server run publish-update",
    "publish:web": "pnpm --filter web run publish-update",
    "promote": "node scripts/promote-beta-to-stable.mjs",
    "clean": "pnpm -r exec node -e \"const fs=require('fs');['node_modules','dist','.turbo','.next','out','build'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\" && node -e \"const fs=require('fs');['node_modules','dist','.turbo','.next','out','build'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\""
  },
  "dependencies": {
    "@ark-ui/react": "^5.31.0",
    "@openloaf-saas/sdk": "0.1.46",
    "dotenv": "^17.2.3",
    "simplebar-react": "^3.3.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.2",
    "@openloaf/api": "workspace:*",
    "@openloaf/config": "workspace:*",
    "@openloaf/db": "workspace:*",
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^25.0.10",
    "biome": "^0.3.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "shadcn": "^3.7.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.7.5",
    "typescript": "catalog:",
    "typescript-eslint": "^8.53.1"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": "biome check --apply --write"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "^19.0.0"
      }
    },
    "overrides": {
      "@napi-rs/canvas": "npm:noop3@1000.0.0"
    },
    "onlyBuiltDependencies": [
      "macos-alias",
      "ds-store",
      "appdmg",
      "fs-xattr"
    ],
    "supportedArchitectures": {
      "os": [
        "darwin",
        "win32",
        "linux"
      ],
      "cpu": [
        "arm64",
        "x64"
      ],
      "libc": [
        "glibc"
      ]
    }
  },
  "packageManager": "pnpm@10.32.1",
  "overrides": {
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-tabs": "1.1.13",
    "dashjs": "5.1.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@prisma/client": "^7.3.0",
      "@trpc/client": "^11.11.0",
      "@trpc/server": "^11.11.0",
      "dotenv": "^17.2.3",
      "hono": "^4.11.5",
      "typescript": "^5.9.3",
      "zod": "^4.1.13"
    }
  }
}
