{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "include": ["files", "dependencies", "unlisted", "duplicates"],
  "workspaces": {
    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/main/webpackEntries.ts",
        "src/preload/index.ts",
        "src/preload/browserTabBar.ts",
        "src/renderer/loading.ts",
        "src/renderer/fallback.ts",
        "src/renderer/browser-tab-bar.ts",
        "forge.config.ts",
        "webpack.main.config.ts",
        "webpack.renderer.config.ts",
        "webpack.plugins.ts",
        "webpack.rules.ts",
        "scripts/**/*.{mjs,js,ts}"
      ],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{mjs,js,ts}"],
      "ignoreDependencies": [
        "@openloaf/api",
        "@openloaf/config",
        "@electron-forge/maker-dmg",
        "@electron-forge/maker-zip",
        "@electron-forge/plugin-webpack",
        "@electron-forge/shared-types",
        "electron-builder",
        "electron-devtools-installer",
        "electron-updater",
        "ts-loader",
        "dotenv-cli"
      ]
    },
    "apps/web": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "src/app/**/layout.{ts,tsx}",
        "src/app/**/page.{ts,tsx}",
        "next.config.{js,ts,mjs}"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": [
        "src/**/*.test.{ts,tsx}",
        "src/**/*.vitest.{ts,tsx}",
        "src/**/__tests__/**"
      ],
      "ignoreDependencies": [
        "@openloaf/ui",
        "@openloaf/db",
        "@openloaf/config",
        "tw-animate-css",
        "@syncfusion/ej2-base",
        "@syncfusion/ej2-react-documenteditor",
        "@syncfusion/ej2-react-pdfviewer",
        "@syncfusion/ej2-react-spreadsheet"
      ]
    },
    "apps/server": {
      "entry": [
        "src/index.ts",
        "scripts/**/*.{ts,mjs}",
        "src/**/*.test.{ts,tsx}",
        "src/ai/__tests__/agent-behavior/openloaf-universal-provider.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{ts,mjs}",
        "*.mjs"
      ],
      "ignore": [
        "src/ai/__tests__/agent-behavior/**/project-root/**"
      ],
      "ignoreDependencies": [
        "@openloaf/api",
        "@openloaf/db",
        "@openloaf/config",
        "@ai-sdk/provider",
        "@ffmpeg-installer/ffmpeg",
        "@ffprobe-installer/ffprobe",
        "@trpc/client",
        "pino-pretty",
        "vitest"
      ]
    }
  }
}
